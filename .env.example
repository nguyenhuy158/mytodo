GOOGLE_SHEET_ID=1Sv86oc9zXbvwSsD956uT4opSU8JqP04s
GOOGLE_SHEET_GID=689856921

# Google auth: choose ONE option below.

# Option A - best for Docker/Dokploy: base64 the whole service-account JSON file.
# Generate on macOS/Linux:
# base64 < /absolute/path/to/service-account.json | tr -d '\n'
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...

# Option B - local development with a service-account JSON file.
# Do not use this in Docker/Dokploy unless the file is mounted into the container.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option C - deployment providers that support escaped newlines.
# Paste the service-account values directly into env, without committing real secrets.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

NEXT_PUBLIC_TASK_POLLING_MS=15000
TASK_CACHE_TTL_MS=60000

# Optional hidden Google Sheet tab for activity log. Auto-created and hidden if missing.
TASK_HISTORY_SHEET_TITLE=Activity Log

# Google login. Only these emails can view the website and call /api/tasks.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-byte-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_ALLOWED_EMAILS=you@example.com,teammate@example.com
AUTH_DEBUG=false

# Public app URLs used by Auth.js redirects and magic login emails.
# Local example: http://localhost:3000
# Deploy example: https://tasks.example.com
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Optional Resend magic-link login. Leave RESEND_API_KEY or MAGIC_LINK_FROM empty
# to hide magic-link login and allow Google login only.
# Example:
# RESEND_API_KEY=re_xxxxxxxxx
# MAGIC_LINK_FROM="2026 Tasks <login@your-domain.com>"
RESEND_API_KEY=
MAGIC_LINK_FROM=
MAGIC_LINK_TTL_MINUTES=15

# Optional Gemini AI summaries. Leave GEMINI_API_KEY empty to keep AI actions off.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional. If omitted, the app finds the sheet title from GOOGLE_SHEET_GID.
# GOOGLE_SHEET_RANGE="'To-Do List'!A1:O"

# Optional for XLSX files opened in Google Sheets. Defaults to the first sheet.
# GOOGLE_XLSX_SHEET_NAME=To-Do List
