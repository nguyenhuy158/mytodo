GOOGLE_SHEET_ID=1Sv86oc9zXbvwSsD956uT4opSU8JqP04s
GOOGLE_SHEET_GID=689856921

# Google auth: choose ONE option below.

# Option A - local development with a service-account JSON file.
# Do not use this in Docker/Dokploy unless the file is mounted into the container.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B - Docker/Dokploy/deployment providers.
# Paste the service-account values directly into env, without committing real secrets.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

NEXT_PUBLIC_TASK_POLLING_MS=15000
TASK_CACHE_TTL_MS=60000

# Google login. Only these emails can view the website and call /api/tasks.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-byte-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_ALLOWED_EMAILS=you@example.com,teammate@example.com
AUTH_DEBUG=false

# Optional. If omitted, the app finds the sheet title from GOOGLE_SHEET_GID.
# GOOGLE_SHEET_RANGE="'To-Do List'!A1:N"

# Optional for XLSX files opened in Google Sheets. Defaults to the first sheet.
# GOOGLE_XLSX_SHEET_NAME=To-Do List
